{
    "name": "mcp-sentry",
    "version": "1.4.0",
    "description": "MCP server for Sentry API",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CynepHy6/mcp-sentry.git"
    },
    "bugs": {
        "url": "https://github.com/CynepHy6/mcp-sentry/issues"
    },
    "homepage": "https://github.com/CynepHy6/mcp-sentry#readme",
    "main": "build/index.js",
    "type": "module",
    "bin": {
        "mcp-sentry": "./build/index.js"
    },
    "scripts": {
        "compile": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
        "prepublishOnly": "npm run compile",
        "start": "node ./build/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "files": [
        "build",
        "LICENSE"
    ],
    "keywords": [
        "mcp",
        "sentry",
        "cursor",
        "npx",
        "error-monitoring"
    ],
    "author": "",
    "license": "ISC",
    "engines": {
        "node": ">=22"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^22.13.9",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.6.1",
        "@sentry/api": "^0.188.0",
        "dotenv": "^16.4.7",
        "zod": "^3.24.2"
    }
}
